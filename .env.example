# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Supabase)
# For migrations and local development
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
# For direct connection (required by prisma.config.ts)
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Auth Configuration
JWT_SECRET="your_jwt_secret_here"
REQUIRE_EMAIL_VERIFICATION=false

# CORS Configuration
# CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# Google OAuth Configuration (Optional, for Google Login)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Email Configuration (Choose either SMTP or Gmail API)

# Option 1: Regular SMTP (Mailtrap, Brevo, etc.)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="no-reply@nutrigrow.com"

# Option 2: Gmail API (Preferred)
# GMAIL_USER="your_gmail@gmail.com"
# GMAIL_REFRESH_TOKEN="your_gmail_refresh_token"

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"
