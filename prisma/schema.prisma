  sd2neg_boy   Float?
  sd2pos_boy   Float?

  @@map("bmi")
}

enum MetodeKonsultasi {
  VIDEO_CALL
  CHAT
}

enum Role {
  USER
  AHLI_GIZI
  ADMIN
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusGizi {
  NORMAL
  STUNTED
  SEVERELY_STUNTED
  WASTED
  SEVERELY_WASTED
}

enum KategoriProduk {
  MPASI
  SUPLEMEN
  ALAT
  PAKET
}

enum KategoriArtikel {
  STUNTING
  GIZI
  MPASI
  KEHAMILAN
  MENYUSUI
}

enum JenisTransaksi {
  SHOP
  TELE_NUTRITIONIST
}

enum StatusBayar {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  REFUND
}

enum StatusKonsultasi {
  BOOKED
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MetodePengiriman {
  STANDARD
  EXPRESS
}

enum FaseKesehatan {
  REMAJA
  HAMIL
  MENYUSUI
}
