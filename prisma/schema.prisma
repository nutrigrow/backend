generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUM DEFINITIONS
// ============================================

enum Role {
  USER
  AHLI_GIZI
  ADMIN
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusGizi {
  NORMAL
  STUNTED
  SEVERELY_STUNTED
  WASTED
  SEVERELY_WASTED
}

enum KategoriProduk {
  MPASI
  SUPLEMEN
  ALAT
  PAKET
}

enum KategoriArtikel {
  STUNTING
  GIZI
  MPASI
  KEHAMILAN
  MENYUSUI
}

enum JenisTransaksi {
  SHOP
  TELE_NUTRITIONIST
}

enum StatusBayar {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  REFUND
}

enum StatusKonsultasi {
  BOOKED
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MetodePengiriman {
  STANDARD
  EXPRESS
}

// ============================================
// TABLE DEFINITIONS
// ============================================

model User {
  id              Int       @id @default(autoincrement())
  nama            String
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  googleId        String?   @unique @map("google_id")
  avatarUrl       String?   @map("avatar_url")
  role            Role      @default(USER)
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  balita          Balita[]
  logKesehatanIbu LogKesehatanIbu[]
  transaksi       Transaksi[]
  konsultasi      Konsultasi[]     @relation("PasienKonsultasi")
  refreshTokens    RefreshToken[]
  profilAhliGizi   ProfilAhliGizi?
  keranjang        Keranjang[]
  alamatPengiriman AlamatPengiriman[]

  @@map("users")
}

model Balita {
  id           Int          @id @default(autoincrement())
  userId       Int          @map("user_id")
  namaAnak     String       @map("nama_anak")
  tanggalLahir DateTime     @map("tanggal_lahir") @db.Date
  jenisKelamin JenisKelamin @map("jenis_kelamin")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  rekamPertumbuhan RekamPertumbuhan[]

  @@index([userId])
  @@map("balita")
}

model RekamPertumbuhan {
  id               Int         @id @default(autoincrement())
  balitaId         Int         @map("balita_id")
  tanggalCatat     DateTime    @map("tanggal_catat") @db.Date
  beratBadan       Float       @map("berat_badan")
  tinggiBadan      Float       @map("tinggi_badan")
  zScoreBbU        Float?      @map("z_score_bb_u")
  zScoreTbU        Float?      @map("z_score_tb_u")
  zScoreBbTb       Float?      @map("z_score_bb_tb")
  statusGizi       StatusGizi? @map("status_gizi")
  risikoStuntingMl String?     @map("risiko_stunting_ml")
  mlConfidence     Float?      @map("ml_confidence")
  createdAt        DateTime    @default(now()) @map("created_at")

  balita Balita @relation(fields: [balitaId], references: [id], onDelete: Cascade)

  @@index([balitaId])
  @@index([tanggalCatat])
  @@map("rekam_pertumbuhan")
}

model LogKesehatanIbu {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  tanggalCatat    DateTime  @map("tanggal_catat") @db.Date
  asupanZatBesiMg Float     @map("asupan_zat_besi_mg")
  jadwalKontrol   DateTime? @map("jadwal_kontrol") @db.Date
  catatan         String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("log_kesehatan_ibu")
}

model ProdukNutrishop {
  id         Int            @id @default(autoincrement())
  namaProduk String         @map("nama_produk")
  deskripsi  String?
  kategori   KategoriProduk
  gambarUrl  String?        @map("gambar_url")
  harga      Int
  stok       Int            @default(0)
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  detailTransaksi DetailTransaksi[]
  keranjang       Keranjang[]

  @@map("produk_nutrishop")
}

model Transaksi {
  id                    Int            @id @default(autoincrement())
  userId                Int            @map("user_id")
  midtransOrderId       String         @unique @map("midtrans_order_id")
  midtransTransactionId String?        @map("midtrans_transaction_id")
  jenisTransaksi        JenisTransaksi @map("jenis_transaksi")
  totalHarga            Int            @map("total_harga")
  statusBayar           StatusBayar    @default(PENDING) @map("status_bayar")
  snapToken             String?        @map("snap_token")
  paymentType           String?        @map("payment_type")
  tanggalTransaksi      DateTime       @default(now()) @map("tanggal_transaksi")
  paidAt                DateTime?         @map("paid_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  
  alamatId              Int?              @map("alamat_id")
  metodePengiriman      MetodePengiriman? @map("metode_pengiriman")
  biayaPengiriman       Int               @default(0) @map("biaya_pengiriman")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  detailTransaksi DetailTransaksi[]
  konsultasi      Konsultasi?
  alamat          AlamatPengiriman? @relation(fields: [alamatId], references: [id])

  @@index([userId])
  @@index([statusBayar])
  @@map("transaksi")
}

model DetailTransaksi {
  id          Int      @id @default(autoincrement())
  transaksiId Int      @map("transaksi_id")
  produkId    Int      @map("produk_id")
  kuantitas   Int
  hargaSatuan Int      @map("harga_satuan")
  subtotal    Int
  createdAt   DateTime @default(now()) @map("created_at")

  transaksi Transaksi       @relation(fields: [transaksiId], references: [id], onDelete: Cascade)
  produk    ProdukNutrishop @relation(fields: [produkId], references: [id])

  @@index([transaksiId])
  @@map("detail_transaksi")
}

model ProfilAhliGizi {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  sertifikasi     String
  spesialisasi    String?
  biayaKonsultasi Int      @map("biaya_konsultasi")
  fotoUrl         String?  @map("foto_url")
  bio             String?
  isAvailable     Boolean  @default(true) @map("is_available")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  konsultasi Konsultasi[]

  @@map("profil_ahli_gizi")
}

model Konsultasi {
  id                Int              @id @default(autoincrement())
  userId            Int              @map("user_id")
  ahliGiziId        Int              @map("ahli_gizi_id")
  transaksiId       Int?             @unique @map("transaksi_id")
  jadwalSesi        DateTime         @map("jadwal_sesi")
  durasiMenit       Int              @default(30) @map("durasi_menit")
  status            StatusKonsultasi @default(BOOKED)
  catatanKonsultasi String?          @map("catatan_konsultasi")
  linkMeeting       String?          @map("link_meeting")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user      User           @relation("PasienKonsultasi", fields: [userId], references: [id], onDelete: Cascade)
  ahliGizi  ProfilAhliGizi @relation(fields: [ahliGiziId], references: [id])
  transaksi Transaksi?     @relation(fields: [transaksiId], references: [id])

  @@index([userId])
  @@index([ahliGiziId])
  @@index([jadwalSesi])
  @@map("konsultasi")
}

model ArtikelEdukasi {
  id          Int             @id @default(autoincrement())
  judul       String
  konten      String
  kategori    KategoriArtikel
  gambarUrl   String?         @map("gambar_url")
  penulis     String?
  isPublished Boolean         @default(false) @map("is_published")
  publishedAt DateTime?       @map("published_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("artikel_edukasi")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Keranjang {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  produkId  Int      @map("produk_id")
  kuantitas Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  produk    ProdukNutrishop @relation(fields: [produkId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("keranjang")
}

model AlamatPengiriman {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  namaPenerima  String   @map("nama_penerima")
  noTelepon     String   @map("no_telepon")
  alamatLengkap String   @map("alamat_lengkap")
  kelurahan     String
  kecamatan     String
  kota          String
  kodePos       String   @map("kode_pos")
  isUtama       Boolean  @default(false) @map("is_utama")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaksi     Transaksi[] 

  @@map("alamat_pengiriman")
}
